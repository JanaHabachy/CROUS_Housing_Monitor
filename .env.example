# Copy this file to `.env` (NOT committed - see .gitignore) and fill in
# real values for local testing, then run:
#   set -a; source .env; set +a; python main.py
#
# In GitHub Actions these same names are read from GitHub Secrets instead
# (Settings > Secrets and variables > Actions), so nothing here is ever
# committed to the repository.

# --- Required (email delivery) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-account@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-account@gmail.com
EMAIL_TO=jana.habachy@gmail.com

# --- Optional (defaults shown) ---
# SMTP_USE_TLS=true
# CROUS_HEARTBEAT_INTERVAL_HOURS=48
# CROUS_REQUEST_TIMEOUT=20
# CROUS_MAX_RETRIES=5
# CROUS_RETRY_BACKOFF_BASE=2
# CROUS_REQUEST_DELAY=1
# CROUS_MAX_PAGES=20
# CROUS_SEARCHES_FILE=config/searches.yaml
# CROUS_STATE_FILE=state/seen_listings.json
